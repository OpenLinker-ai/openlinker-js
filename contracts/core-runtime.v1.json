{
  "name": "openlinker-core-runtime",
  "version": "v1",
  "package": "@openlinker/sdk",
  "scope": "core-runtime",
  "rules": {
    "adapter_free": true,
    "forbidden_path_prefixes": [
      "/api/v1/cloud",
      "/api/v1/tasks",
      "/api/v1/task-templates",
      "/api/v1/workflows",
      "/api/v1/workflow-runs",
      "/api/v1/billing",
      "/api/v1/wallet",
      "/api/v1/stripe"
    ]
  },
  "endpoints": [
    {
      "client_method": "heartbeatAgent",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/heartbeat",
      "auth": "runtime_token",
      "required_scope": "agent:pull",
      "source": "openlinker-core/pkg/runtime/handler.go"
    },
    {
      "client_method": "claimRuntimeRun",
      "http_method": "GET",
      "path": "/api/v1/agent-runtime/runs/claim",
      "auth": "runtime_token",
      "required_scope": "agent:pull",
      "source": "openlinker-core/pkg/runtime/handler.go"
    },
    {
      "client_method": "completeRuntimeRun",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/runs/{id}/result",
      "auth": "runtime_token",
      "required_scope": "agent:pull",
      "source": "openlinker-core/pkg/runtime/handler.go"
    },
    {
      "client_method": "callAgent",
      "http_method": "POST",
      "path": "/api/v1/agent-runtime/call-agent",
      "auth": "runtime_token",
      "required_scope": "agent:call",
      "source": "openlinker-core/pkg/a2a/handler.go"
    }
  ],
  "protocol_types": [
    "AgentHeartbeatResponse",
    "RuntimePullRunResponse",
    "RuntimePullResultRequest",
    "RuntimeWSClientMessage",
    "RuntimeWSServerMessage",
    "CallAgentRequest"
  ]
}
